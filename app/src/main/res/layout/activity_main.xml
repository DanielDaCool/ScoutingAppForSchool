<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#0D0D14">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScoutingApp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:textColor="#F0E6FF" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שלום, משתמש"
            android:textSize="16sp"
            android:textColor="#7C6F8E"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#16102A" />

    <!-- Panels container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ===== HOME PANEL ===== -->
        <ScrollView
            android:id="@+id/panelHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0A0A0F"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Welcome banner card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_purple"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvWelcomeBanner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ברוך הבא 👋"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#F0E6FF"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="מוכן לסקאוטינג היום?"
                        android:textSize="13sp"
                        android:textColor="#C084FC" />
                </LinearLayout>

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="סיכום נתונים"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Stats cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvTeamCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="מספר קבוצות בתחרות"
                            android:textSize="14sp"
                            android:textColor="#7C6F8E" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvGamesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="משחקים אחרי סקאוטינג"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:textColor="#7C6F8E" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="פעולות מהירות"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Forms - full width primary -->
                <Button
                    android:id="@+id/btnForms"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="12dp"
                    android:text="📝   מלא טופס סקאוטינג"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />


                <Button
                    android:id="@+id/btnPrediction"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="12dp"
                    android:text="🤖   חיזוי תוצאת משחק לפי נתונים"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </ScrollView>

        <!-- ===== PROFILE PANEL ===== -->
        <LinearLayout
            android:id="@+id/panelProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp"
            android:background="#0A0A0F"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="64sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם מלא"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F0E6FF"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@example.com"
                android:textSize="14sp"
                android:textColor="#7C6F8E"
                android:layout_marginBottom="48dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#16102A"
                android:layout_marginBottom="48dp" />

            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="התנתק"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"
                android:background="@drawable/btn_danger"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#16102A" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D14"

        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:itemActiveIndicatorStyle="@null"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>