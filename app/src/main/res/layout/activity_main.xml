<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#0D0D14">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScoutingApp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:textColor="#F0E6FF" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שלום, משתמש"
            android:textSize="16sp"
            android:textColor="#7C6F8E"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#16102A" />

    <!-- Panels container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ===== HOME PANEL ===== -->
        <ScrollView
            android:id="@+id/panelHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0A0A0F"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Welcome banner card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_purple"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tvWelcomeBanner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ברוך הבא 👋"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#F0E6FF"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="מוכן לסקאוטינג היום?"
                        android:textSize="13sp"
                        android:textColor="#C084FC"
                        android:layout_marginBottom="12dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#3D2A5C"
                        android:layout_marginBottom="12dp" />

                    <!-- Current event row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆 תחרות נוכחית:"
                            android:textSize="13sp"
                            android:textColor="#7C6F8E"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tvCurrentEvent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="סיכום נתונים"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Stats cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvTeamCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="מספר קבוצות בתחרות"
                            android:textSize="14sp"
                            android:textColor="#7C6F8E" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvGamesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="משחקים אחרי סקאוטינג"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:textColor="#7C6F8E" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="פעולות מהירות"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Forms button -->
                <Button
                    android:id="@+id/btnForms"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="12dp"
                    android:text="📝   מלא טופס סקאוטינג"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

                <!-- Prediction button -->
                <Button
                    android:id="@+id/btnPrediction"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="12dp"
                    android:text="🤖   חיזוי תוצאת משחק לפי נתונים"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </ScrollView>

        <!-- ===== PROFILE PANEL ===== -->
        <LinearLayout
            android:id="@+id/panelProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <!-- User info card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A1025"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="שם משתמש"
                        android:textColor="#F0E6FF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textColor="#7C6F8E"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <!-- Role badge -->
                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="👤 Scouter"
                        android:textColor="#7C6F8E"
                        android:textSize="13sp"
                        android:background="#2A1F3D"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Admin panel button — only visible for ADMIN -->
            <Button
                android:id="@+id/btnAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ניהול משימות 🔑"
                android:textColor="#F0E6FF"
                android:backgroundTint="#2A1F3D"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Assignment list — only visible for SCOUTER -->
            <LinearLayout
                android:id="@+id/layoutAssignments"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="המשימות שלי"
                    android:textColor="#F0E6FF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvNoAssignments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="אין משימות פתוחות ✓"
                    android:textColor="#7C6F8E"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAssignments"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scrollbars="vertical" />

            </LinearLayout>

            <!-- Logout button always at bottom -->
            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="התנתק"
                android:textColor="#FF5050"
                android:backgroundTint="#1A0A0A"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#16102A" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D14"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:itemActiveIndicatorStyle="@null"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>