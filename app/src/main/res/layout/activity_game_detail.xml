                            android:text="טיפוס: —"
                            android:textColor="#F0E6FF"
                            android:textSize="12sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvBlueGames2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="משחקים: 0"
                            android:textColor="#7C6F8E"
                            android:textSize="11sp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Blue Team 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#0A0A1F"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvBlueTeam3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="#0000"
                            android:textColor="#80AAFF"
                            android:textSize="15sp"
