                            android:id="@+id/tvRedHeight2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="גובה: —"
                            android:textColor="#C084FC"
                            android:textSize="12sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvRedClimb2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="טיפוס: —"
                            android:textColor="#F0E6FF"
                            android:textSize="12sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvRedGames2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="משחקים: 0"
                            android:textColor="#7C6F8E"
                            android:textSize="11sp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Red Team 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#1F0A0A"
                        android:padding="10dp">

