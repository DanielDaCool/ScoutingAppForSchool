<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0A0F"
    android:padding="32dp">


    <ImageView
        android:layout_width="200sp"
        android:layout_height="200sp"
        android:src="@drawable/demacia_logo">
    </ImageView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scouting App"
        android:textColor="#F0E6FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <!-- Loading state -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:progressTint="#C084FC"
        android:max="100" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מאתחל..."
        android:textColor="#7C6F8E"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvPercent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="#C084FC"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- No internet state — hidden by default -->
    <TextView
        android:id="@+id/tvNoInternet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="אין חיבור לאינטרנט &#10;&#10;נדרש חיבור לאינטרנט בכניסה הראשונה לאפליקציה"
        android:textColor="#F0E6FF"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnRetry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="נסה שוב"
        android:textColor="#F0E6FF"
        android:backgroundTint="#2A1F3D"
        android:visibility="gone" />

</LinearLayout>