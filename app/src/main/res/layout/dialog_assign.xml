<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מספר משחק"
        android:textColor="#F0E6FF"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etAssignGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="לדוגמה: 5"
        android:textColor="#F0E6FF"
        android:textColorHint="#7C6F8E"
        android:backgroundTint="#C084FC"
        android:padding="10dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מספר קבוצה"
        android:textColor="#F0E6FF"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etAssignTeam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="לדוגמה: 5635"

        android:textColor="#F0E6FF"
        android:textColorHint="#7C6F8E"
        android:backgroundTint="#C084FC"
        android:padding="10dp" />

</LinearLayout>