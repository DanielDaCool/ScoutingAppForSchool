<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="חיזוי לפי משחק"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#F0E6FF"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Game Selection Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_dark"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="בחר משחק"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C084FC"
                android:layout_marginBottom="12dp" />

            <!-- Spinner wrapped in a visible dark container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A1F3D"
                android:layout_marginBottom="16dp"
                android:padding="4dp">

                <Spinner
                    android:id="@+id/spinnerGames"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#C084FC"
                    android:popupBackground="#1C1530"
                    android:padding="8dp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnPredict"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="חשב חיזוי"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Alliance Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_dark"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ברית אדומה"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtRedAlliance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="14sp"
                android:textColor="#7C6F8E"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#16102A"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ברית כחולה"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtBlueAlliance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="14sp"
                android:textColor="#7C6F8E" />
        </LinearLayout>

        <!-- Prediction Result Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_dark"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="תוצאת חיזוי"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C084FC"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtPredictionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="בחר משחק כדי לראות חיזוי"
                android:textSize="14sp"
                android:textColor="#7C6F8E"
                android:visibility="visible" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>