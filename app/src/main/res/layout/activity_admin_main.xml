<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#0D0D14">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScoutingApp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#F0E6FF" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/textViewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שלום, Admin 🔑"
            android:textSize="16sp"
            android:textColor="#C084FC"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#16102A" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- HOME PANEL -->
        <ScrollView
            android:id="@+id/panelHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0A0A0F"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg_purple"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="right">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="לוח בקרה 🔑"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="#F0E6FF"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ניהול הסקאוטינג"
                        android:layout_marginTop="10dp"

                        android:textSize="16sp"
                        android:textColor="#C084FC"
                        android:layout_marginBottom="12dp" />




                </LinearLayout>

                <!-- Stats -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="סיכום נתונים"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvTeamCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="קבוצות בתחרות"
                            android:textSize="14sp"
                            android:textColor="#7C6F8E" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_bg_dark">

                        <TextView
                            android:id="@+id/tvGamesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#C084FC" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="משחקים סקאוטינג"
                            android:textSize="14sp"
                            android:textAlignment="center"
                            android:textColor="#7C6F8E" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Actions — NO forms button -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="פעולות"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnAdminPanel"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="12dp"
                    android:text="🔑   ניהול משימות"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnPrediction"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="🤖   חיזוי תוצאת משחק"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </ScrollView>

        <!-- PROFILE PANEL -->
        <LinearLayout
            android:id="@+id/panelProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A1025"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="שם"
                        android:textColor="#F0E6FF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="email"
                        android:textColor="#7C6F8E"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🔑 Admin"
                        android:textColor="#C084FC"
                        android:textSize="13sp"
                        android:background="#2A1F3D"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="התנתק"
                android:textColor="#FF5050"
                android:backgroundTint="#1A0A0A"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </FrameLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#16102A" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D14"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:itemActiveIndicatorStyle="@null"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>